{
  "name": "@vercube/nitro",
  "version": "1.1.4",
  "description": "Nitro module for Vercube framework",
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercube/vercube.git",
    "directory": "packages/nitro"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json",
    "./runtime/handler": "./dist/runtime/RouteHandler.mjs"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "vercube",
    "nitro",
    "framework"
  ],
  "scripts": {
    "build": "tsdown --config ./tsdown.config.ts --config-loader=unrun"
  },
  "dependencies": {
    "@vercube/core": "workspace:*",
    "@vercube/di": "workspace:*",
    "@vercube/scan": "workspace:*",
    "@vercube/storage": "workspace:*",
    "chokidar": "5.0.0",
    "defu": "catalog:",
    "nitro": "catalog:",
    "oxc-parser": "0.138.0",
    "pathe": "catalog:",
    "tinyglobby": "0.2.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
