{
  "name": "vercube-monorepo",
  "version": "1.0.0-beta.2",
  "description": "An ultra-efficient JavaScript server framework that runs anywhere - Node.js, Bun, or Deno - with unmatched flexibility and complete configurability for developers who refuse to sacrifice speed or control.",
  "packageManager": "pnpm@11.8.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build --filter='./packages/*'",
    "dev": "turbo watch build --filter='./packages/*'",
    "test": "vitest run",
    "test:all": "pnpm test && pnpm test:tscheck && pnpm test:lint",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench --run",
    "test:tscheck": "tsgo --noEmit",
    "test:lint": "oxlint . && oxfmt --check",
    "lint:fix": "oxlint --fix . && oxfmt --no-error-on-unmatched-pattern",
    "pre-commit": "lint-staged",
    "postinstall": "simple-git-hooks",
    "playground": "cd playground && pnpm dev",
    "release": "bumpp"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "5.6.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@oxc-project/runtime": "catalog:",
    "@types/node": "25.9.4",
    "@typescript/native-preview": "7.0.0-dev.20260622.1",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "bumpp": "11.1.0",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.3",
    "tslib": "2.8.1",
    "turbo": "2.9.18",
    "unrun": "0.3.1",
    "vitest": "4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm pre-commit",
    "commit-msg": "pnpm commitlint --edit $1",
    "pre-push": "pnpm test && pnpm test:tscheck"
  }
}
